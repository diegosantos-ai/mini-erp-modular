# Copie este arquivo para .env e preencha os valores locais.
# Nao versionar .env.

POSTGRES_DB=minierp
POSTGRES_USER=minierp
POSTGRES_PASSWORD=<defina-uma-senha-local>
POSTGRES_PORT=5432

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/minierp
SPRING_DATASOURCE_USERNAME=minierp
SPRING_DATASOURCE_PASSWORD=<mesma-senha-do-postgres>

JWT_SECRET=<gere-com-openssl-rand-base64-32>
JWT_EXPIRATION=3600

IDENTITY_BOOTSTRAP_ADMIN_ENABLED=true
IDENTITY_BOOTSTRAP_ADMIN_EMAIL=admin@minierp.local
IDENTITY_BOOTSTRAP_ADMIN_PASSWORD=<defina-uma-senha-local>
IDENTITY_BOOTSTRAP_ADMIN_NAME=Administrador
